# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret from Slack App → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── Cron security ─────────────────────────────────────────────────────────────
# Any strong random string — set the same value in cron-job.org request headers
# as   X-Cron-Secret: <this value>
CRON_SECRET=generate-a-strong-random-string-here

# ── Salesforce ────────────────────────────────────────────────────────────────
SF_USERNAME=your-sf-username@company.com
SF_PASSWORD=your-sf-password
SF_SECURITY_TOKEN=your-sf-security-token   # Settings → Reset My Security Token
SF_DOMAIN=login                             # "login" for prod, "test" for sandbox

# ── Session state ─────────────────────────────────────────────────────────────
# Set to /data on Render (persistent disk); leave unset for local dev
# SESSION_DIR=/data
