# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret from Slack App → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── Cron security ─────────────────────────────────────────────────────────────
# Any strong random string — set the same value in cron-job.org request headers
# as   X-Cron-Secret: <this value>
CRON_SECRET=generate-a-strong-random-string-here

# ── Salesforce ────────────────────────────────────────────────────────────────
# Auth URL from: sf org display --verbose --target-org <alias>  (sfdxAuthUrl field)
# Format: force://clientId:clientSecret:refreshToken@instanceHost
SFDX_AUTH_URL=force://PlatformCLI::your-refresh-token@your-instance.my.salesforce.com

# ── Session state ─────────────────────────────────────────────────────────────
# Set to /data on Render (persistent disk); leave unset for local dev
# SESSION_DIR=/data
